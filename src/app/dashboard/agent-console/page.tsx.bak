"use client";

import React from "react";
import { Terminal, Activity, Zap, ShieldAlert, CheckCircle } from "lucide-react";
import { cn } from "@/lib/utils";

export default function AgentConsolePage() {
  return (
    <div className="h-[calc(100vh-80px)] flex flex-col gap-6">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-3xl font-bold tracking-tight">Agent Console</h2>
          <p className="text-zinc-500 mt-1">Live execution logs and orchestrator telemetry.</p>
        </div>
        <div className="flex items-center gap-2 px-3 py-1.5 bg-green-500/10 border border-green-500/20 rounded-full">
          <div className="w-2 h-2 rounded-full bg-green-500 animate-pulse" />
          <span className="text-xs font-bold text-green-500 uppercase tracking-wider">Engine: Online</span>
        </div>
      </div>

      <div className="flex-1 grid grid-cols-3 gap-6 overflow-hidden">
        {/* Logs Console */}
        <div className="col-span-2 glass-panel flex flex-col ring-1 ring-white/5 overflow-hidden">
          <div className="p-4 border-b border-zinc-900 flex items-center justify-between bg-zinc-950/30">
            <div className="flex items-center gap-2">
              <Terminal className="w-4 h-4 text-cyan-400" />
              <span className="text-sm font-bold uppercase tracking-wider text-zinc-400">System Logs</span>
            </div>
            <span className="text-[10px] text-zinc-600 uppercase font-bold">Press ESC to clear</span>
          </div>
          
          <div className="flex-1 overflow-y-auto p-4 font-mono text-xs space-y-2 bg-black/50">
            {[
              { time: "12:04:12", agent: "Orchestrator", msg: "Dispatching job: Future of AI Agents -> COMPOSITION", type: "info" },
              { time: "12:04:15", agent: "CompositionAgent", msg: "Starting master content generation via Gemini-Pro", type: "info" },
              { time: "12:04:45", agent: "CompositionAgent", msg: "Master content generation complete. Tokens: 452. Latency: 32s", type: "success" },
              { time: "12:04:46", agent: "Orchestrator", msg: "Updating state: COMPOSITION -> REPURPOSING", type: "info" },
              { time: "12:04:48", agent: "RepurposingAgent", msg: "Creating platform variants (Twitter, LinkedIn)", type: "info" },
              { time: "12:05:10", agent: "System", msg: "Skill threshold reached: Low confidence on trend analysis path", type: "warning" },
              { time: "12:05:12", agent: "Orchestrator", msg: "Retrying ResearchAgent via OpenAI-GPT fallback", type: "retry" },
            ].map((log, i) => (
              <div key={i} className="flex gap-4 group">
                <span className="text-zinc-600 shrink-0">{log.time}</span>
                <span className={cn(
                  "shrink-0 font-bold",
                  log.agent === "Orchestrator" ? "text-cyan-600" : "text-purple-600"
                )}>[{log.agent}]</span>
                <span className={cn(
                  "transition-colors",
                  log.type === "success" ? "text-green-500" :
                  log.type === "warning" ? "text-yellow-500" :
                  log.type === "retry" ? "text-orange-500" :
                  "text-zinc-300"
                )}>{log.msg}</span>
              </div>
            ))}
          </div>
        </div>

        {/* Telemetry/Sidebar */}
        <div className="flex flex-col gap-6">
          <div className="glass-panel p-5 space-y-4">
            <h4 className="text-sm font-bold uppercase tracking-widest text-zinc-500">Live Telemetry</h4>
            
            <div className="space-y-4">
              {[
                { label: "Active Threads", value: "4", icon: Activity, color: "text-cyan-500" },
                { label: "Queue Load", value: "12%", icon: Zap, color: "text-yellow-500" },
                { label: "Health Score", value: "99", icon: CheckCircle, color: "text-green-500" },
                { label: "Failures (24h)", value: "2", icon: ShieldAlert, color: "text-red-500" },
              ].map((m, i) => (
                <div key={i} className="flex items-center justify-between">
                  <div className="flex items-center gap-2">
                    <m.icon className={cn("w-4 h-4", m.color)} />
                    <span className="text-xs text-zinc-400">{m.label}</span>
                  </div>
                  <span className="text-sm font-bold text-white tracking-widest leading-none">{m.value}</span>
                </div>
              ))}
            </div>
          </div>

          <div className="glass-panel p-5 flex-1 min-h-[200px] flex flex-col gap-4">
            <h4 className="text-sm font-bold uppercase tracking-widest text-zinc-500">Resource usage</h4>
            <div className="flex-1 flex items-end gap-1.5 pb-2">
              {[40, 60, 45, 90, 65, 30, 85, 20, 50, 70, 40].map((h, i) => (
                <div 
                  key={i} 
                  className="w-full bg-cyan-500/20 rounded-sm hover:bg-cyan-500/50 transition-colors cursor-pointer" 
                  style={{ height: `${h}%` }}
                />
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
