"use client";

import React from "react";
import { Cpu, Shield, Zap, ToggleRight, ToggleLeft, Globe, Bot } from "lucide-react";
import { cn } from "@/lib/utils";

const agencies = [
  { 
    title: "Ingestion Agency", 
    skills: [
      { name: "Intake Agent", enabled: true, auto: true },
      { name: "Classify Agent", enabled: true, auto: true },
    ]
  },
  { 
    title: "Knowledge Agency", 
    skills: [
      { name: "Media Extraction", enabled: true, auto: false },
      { name: "Transcription", enabled: true, auto: true },
      { name: "Research Agent", enabled: true, auto: true },
      { name: "Trend Discovery", enabled: false, auto: false },
    ]
  },
  { 
    title: "Production Agency", 
    skills: [
      { name: "Composition", enabled: true, auto: true },
      { name: "Repurposing", enabled: true, auto: true },
      { name: "Visual Gen", enabled: true, auto: false },
      { name: "Clip Creator", enabled: false, auto: false },
    ]
  }
];

export default function SkillsPage() {
  return (
    <div className="space-y-8">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-3xl font-bold tracking-tight">AI Skill Matrix</h2>
          <p className="text-zinc-500 mt-1">Configure autonomous agent roles and permission gates.</p>
        </div>
        
        <div className="flex items-center gap-2 p-1 bg-zinc-900 rounded-lg border border-zinc-800">
          <button className="px-3 py-1.5 text-xs font-bold bg-cyan-500 text-black rounded-md">Production</button>
          <button className="px-3 py-1.5 text-xs font-bold text-zinc-500 hover:text-zinc-300">Sandbox</button>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {/* Skills Management */}
        <div className="lg:col-span-2 space-y-6">
          {agencies.map((agency) => (
            <div key={agency.title} className="glass-panel overflow-hidden border-zinc-800/50">
              <div className="p-4 border-b border-zinc-800 bg-zinc-900/30 flex items-center justify-between">
                <span className="text-sm font-bold uppercase tracking-widest text-zinc-400">{agency.title}</span>
                <span className="text-[10px] text-zinc-600 uppercase font-black">{agency.skills.length} Roles</span>
              </div>
              <div className="divide-y divide-zinc-900">
                {agency.skills.map((skill) => (
                  <div key={skill.name} className="p-4 flex items-center justify-between hover:bg-white/5 transition-colors">
                    <div className="flex items-center gap-4">
                      <div className={cn(
                        "w-8 h-8 rounded bg-zinc-900 border border-zinc-800 flex items-center justify-center",
                        skill.enabled ? "text-cyan-400" : "text-zinc-700"
                      )}>
                        <Bot className="w-4 h-4" />
                      </div>
                      <div>
                        <p className="text-sm font-bold text-zinc-200">{skill.name}</p>
                        <p className="text-[10px] text-zinc-500 uppercase tracking-tighter">
                          {skill.auto ? "Auto-execution allowed" : "Requires permission gate"}
                        </p>
                      </div>
                    </div>
                    <div className="flex items-center gap-3">
                      <button className={cn(
                        "text-xs font-bold px-2 py-1 rounded transition-colors",
                        skill.auto ? "text-cyan-400 bg-cyan-400/10" : "text-zinc-600 bg-zinc-900"
                      )}>AUTO</button>
                      {skill.enabled ? (
                        <ToggleRight className="w-8 h-8 text-cyan-500 cursor-pointer" />
                      ) : (
                        <ToggleLeft className="w-8 h-8 text-zinc-700 cursor-pointer" />
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        {/* Provider Settings */}
        <div className="space-y-6">
          <div className="glass-panel p-5 space-y-6 border-cyan-500/20 shadow-[0_0_30px_rgba(0,242,255,0.05)]">
            <div className="flex items-center gap-2 mb-2">
              <Zap className="w-5 h-5 text-cyan-400" />
              <h4 className="text-sm font-bold uppercase tracking-widest text-zinc-300">Provider Priority</h4>
            </div>

            <div className="space-y-3">
              {[
                { name: "Gemini 1.5 Pro", status: "Active", type: "Cloud" },
                { name: "GPT-4o", status: "Fallback 1", type: "Cloud" },
                { name: "HuggingFace", status: "Fallback 2", type: "Cloud" },
                { name: "Ollama (Local)", status: "Last Resort", type: "Local" },
              ].map((p, i) => (
                <div key={i} className="flex items-center justify-between p-3 bg-zinc-900/50 rounded-lg border border-zinc-800 hover:border-zinc-700 transition-colors cursor-move group">
                  <div className="flex items-center gap-3">
                    <div className="text-[10px] font-bold text-zinc-600 group-hover:text-cyan-500 transition-colors">0{i+1}</div>
                    <div>
                      <p className="text-xs font-bold text-zinc-200">{p.name}</p>
                      <p className="text-[9px] text-zinc-500 uppercase">{p.type}</p>
                    </div>
                  </div>
                  <span className={cn(
                    "text-[9px] font-bold uppercase px-1.5 py-0.5 rounded",
                    i === 0 ? "bg-cyan-500/10 text-cyan-400" : "bg-zinc-800 text-zinc-500"
                  )}>{p.status}</span>
                </div>
              ))}
            </div>

            <button className="w-full py-2.5 bg-zinc-900 border border-zinc-800 rounded-lg text-xs font-bold text-zinc-400 hover:text-cyan-400 hover:border-cyan-500/50 transition-all">
              Test Connection
            </button>
          </div>

          <div className="glass-panel p-5 space-y-4">
             <div className="flex items-center gap-2">
              <Shield className="w-5 h-5 text-purple-400" />
              <h4 className="text-sm font-bold uppercase tracking-widest text-zinc-300">Safety Gates</h4>
            </div>
            <p className="text-[11px] text-zinc-500 leading-relaxed">
              Global safety settings for all agents. Enabling mandatory review will force a manual gate on every content package regardless of confidence scores.
            </p>
            <div className="flex items-center justify-between p-3 bg-purple-500/5 border border-purple-500/10 rounded-lg">
              <span className="text-xs font-bold text-zinc-300">Mandatory Review</span>
              <ToggleLeft className="w-8 h-8 text-zinc-700 cursor-pointer" />
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
